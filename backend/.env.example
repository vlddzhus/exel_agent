# ── Primary LLM provider (OpenAI-compatible) ──
# claude-haiku-4-5 через агрегатор j3gb. Вставьте свой ключ.
# Примечание: DeepSeek на провайдере j3gb.com отсутствует.
OPENMODEL_API_KEY=sk-YOUR-KEY-HERE
OPENMODEL_BASE_URL=https://vip.j3gb.com/v1
OPENMODEL_MODEL=claude-haiku-4-5

# Универсальное имя модели (приоритет для всех OpenAI-совместимых провайдеров)
MODEL_NAME=claude-haiku-4-5

# ── Fallback providers (заполнить при наличии) ──
# OPENAI_API_KEY=sk-...
# GROQ_API_KEY=gsk_...
# ANTHROPIC_API_KEY=sk-ant-...

# ── Server ──
PORT=4000
NODE_ENV=development
ALLOWED_ORIGINS=https://localhost:3000,https://localhost:3001,http://localhost:3000

# ── Rate limiting ──
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200

# ── Security (в dev авто-генерируется; в prod — случайный ≥32 символа) ──
JWT_SECRET=CHANGE-ME-USE-RANDOM-64-CHARS

# ── Payments (ЮKassa) — только prod; в dev обойдён ──
YOOKASSA_SHOP_ID=PLACEHOLDER
YOOKASSA_SECRET_KEY=PLACEHOLDER

# ── PostgreSQL (docker compose up -d) ──
DATABASE_URL=postgresql://excelagent:dev_password_change_me@localhost:5432/excel_agent

# ── Redis (опционально) ──
# REDIS_URL=redis://localhost:6379

# ── Default model ──
DEFAULT_MODEL=claude-haiku-4-5
